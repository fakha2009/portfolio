Options -Indexes

RewriteEngine On
RewriteBase /

RewriteRule ^(?:app|config|storage|templates|vendor)(?:/|$) - [F,L,NC]
RewriteRule (^|/)\.(?!well-known/) - [F,L,NC]
RewriteRule \.(?:sql|log|md|dist)$ - [F,L,NC]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index.php [L,QSA]
