{
  "version": 2,
  "alias": ["fakhriddin-portfolio.vercel.app"],
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "api/admin/messages.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "api/admin/overview.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "api/admin/content.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "^/api/admin/messages\\.php$",
      "dest": "/api/admin/messages.php"
    },
    {
      "src": "^/api/admin/overview\\.php$",
      "dest": "/api/admin/overview.php"
    },
    {
      "src": "^/api/admin/content\\.php$",
      "dest": "/api/admin/content.php"
    },
    {
      "src": "^/assets/(.*)$",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "src": "^/assets/(.*)$",
      "dest": "/assets/$1"
    },
    {
      "src": "^/uploads/(.*)$",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "src": "^/uploads/(.*)$",
      "dest": "/uploads/$1"
    },
    {
      "src": "^/(.*\\.(?:ico|png|svg|jpg|jpeg|webp|css|js|woff2?|ttf|eot|map))$",
      "dest": "/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/index.php"
    }
  ],
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/uploads/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
